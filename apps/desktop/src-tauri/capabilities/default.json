{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main", "widget"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/ocr-engine",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-open",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load"
  ]
}
